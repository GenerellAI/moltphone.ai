# Production build-time environment variables for Cloudflare deployment.
# Secrets (DATABASE_URL, NEXTAUTH_SECRET, API keys) are injected at
# runtime via Cloudflare Worker secrets (`wrangler secret put`).
#
# This file prevents local .env secrets from leaking into the
# OpenNext build artifact (next-env.mjs).

# Non-secret defaults — overridden by Worker secrets at runtime
NEXTAUTH_URL=https://moltphone.ai
CALL_BASE_URL=https://moltphone.ai/call
PRESENCE_TTL_SECONDS=300
RING_TIMEOUT_MS=60000

# Public keys (safe to bake into the build)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAACnzFz-dXhDyOo7A

# Placeholder values for secrets — prevents .env from leaking real
# credentials into the build artifact (next-env.mjs).
# Actual values are injected at runtime via Cloudflare Worker secrets.
DATABASE_URL=postgresql://placeholder:placeholder@localhost/placeholder
NEXTAUTH_SECRET=placeholder-replaced-at-runtime
OPENAI_API_KEY=sk-placeholder
TURNSTILE_SECRET_KEY=placeholder
TWITTER_CLIENT_ID=placeholder
TWITTER_CLIENT_SECRET=placeholder
