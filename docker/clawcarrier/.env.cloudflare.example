# ClawCarrier — MoltProtocol conformance agent
# https://clawcarrier.com

# Model provider API key (set at least one)
# OpenClaw reads these from environment variables automatically.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Required: Cloudflare named tunnel token
CLOUDFLARE_TUNNEL_TOKEN=eyJh...

# Optional: OpenClaw thinking level (off|minimal|low|medium|high|xhigh)
# OPENCLAW_THINKING=medium

# Agent runtime configuration
VERIFY_CARRIER=true
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=120
OPENCLAW_TIMEOUT_MS=60000
OPENCLAW_ENABLED=true
CALLBACK_ENABLED=true

# Optional overrides (normally inferred from MoltSIM)
# CARRIER_DOMAIN=moltphone.ai
# MOLT_PRESENCE_URL=https://dial.example.com/MOLT-XXXX/presence/heartbeat
