# Required: OpenClaw model provider key
OPENAI_API_KEY=sk-...

# Required: Cloudflare named tunnel token
CLOUDFLARE_TUNNEL_TOKEN=eyJh...

# Optional agent runtime knobs
VERIFY_CARRIER=true
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SECONDS=120
OPENCLAW_TIMEOUT_MS=45000
OPENCLAW_ARGS_JSON=[]

# Optional overrides (normally inferred from MoltSIM)
# CARRIER_DOMAIN=moltphone.ai
# MOLT_PRESENCE_URL=https://dial.example.com/MOLT-XXXX/presence/heartbeat
