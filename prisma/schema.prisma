generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  nations       Nation[]
  agents        Agent[]
  favorites     Favorite[]
  blocks        Block[]
}

model Nation {
  id           String   @id @default(cuid())
  code         String   @unique
  displayName  String
  description  String?
  badge        String?
  isPublic     Boolean  @default(true)
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  agents       Agent[]
}

enum InboundPolicy {
  public
  registered_only
  allowlist
}

enum ForwardCondition {
  always
  when_offline
  when_busy
  when_dnd
}

enum DirectConnectionPolicy {
  direct_on_consent
  direct_on_accept
  carrier_only
}

// ── Agent ────────────────────────────────────────────────

model Agent {
  id                   String        @id @default(cuid())
  phoneNumber          String        @unique
  nationCode           String
  nation               Nation        @relation(fields: [nationCode], references: [code])
  ownerId              String
  owner                User          @relation(fields: [ownerId], references: [id])
  
  displayName          String
  description          String?
  avatarUrl            String?
  skills               String[]      @default([])
  
  endpointUrl          String?
  dialEnabled          Boolean       @default(true)
  
  // Ed25519 public key (SPKI DER, base64url).  Private key lives in the MoltSIM.
  publicKey            String?
  
  awayMessage          String?       @db.VarChar(500)
  
  directConnectionPolicy DirectConnectionPolicy @default(direct_on_consent)
  
  lastSeenAt           DateTime?
  
  inboundPolicy        InboundPolicy @default(public)
  allowlistAgentIds    String[]      @default([])
  
  dndEnabled           Boolean       @default(false)
  
  maxConcurrentCalls   Int           @default(3)
  
  callForwardingEnabled Boolean       @default(false)
  forwardToAgentId     String?
  forwardCondition     ForwardCondition @default(when_offline)
  
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  
  tasksAsCallee        Task[]        @relation("CalleeAgent")
  tasksAsCaller        Task[]        @relation("CallerAgent")
  favorites            Favorite[]
  blocksAsTarget       Block[]       @relation("BlockedAgent")
  forwardedFrom        Agent[]       @relation("ForwardedTo")
  forwardTo            Agent?        @relation("ForwardedTo", fields: [forwardToAgentId], references: [id])
  socialVerifications  SocialVerification[]
  domainClaims         DomainClaim[]
}

// ── Task (replaces Call) — A2A states ────────────────────

enum TaskIntent {
  call
  text
}

enum TaskStatus {
  submitted
  working
  input_required
  completed
  canceled
  failed
}

model Task {
  id             String     @id @default(cuid())
  taskId         String?    // A2A external task ID (set by caller)
  sessionId      String?    // A2A session ID for multi-turn
  callerId       String?
  caller         Agent?     @relation("CallerAgent", fields: [callerId], references: [id])
  calleeId       String
  callee         Agent      @relation("CalleeAgent", fields: [calleeId], references: [id])
  intent         TaskIntent @default(call)
  status         TaskStatus @default(submitted)
  forwardingHops String[]   @default([])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  messages       TaskMessage[]
  events         TaskEvent[]
}

model TaskMessage {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  role      String
  // JSON array of typed parts: TextPart | DataPart | FilePart
  parts     Json     @default("[]")
  createdAt DateTime @default(now())
}

// TaskEvent: event log for live monitoring / SSE reconnect
model TaskEvent {
  id             String   @id @default(cuid())
  taskId         String
  task           Task     @relation(fields: [taskId], references: [id])
  type           String
  payload        Json     @default("{}")
  sequenceNumber Int
  timestamp      DateTime @default(now())
  
  @@index([taskId, sequenceNumber])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())
  
  @@unique([userId, agentId])
}

model Block {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  blockedAgentId  String
  blockedAgent    Agent    @relation("BlockedAgent", fields: [blockedAgentId], references: [id])
  reason          String?
  createdAt       DateTime @default(now())
  
  @@unique([userId, blockedAgentId])
}

model NonceUsed {
  nonce     String   @id
  usedAt    DateTime @default(now())
  expiresAt DateTime
}

// ── Social Verification ─────────────────────────────────

enum VerificationProvider {
  domain
  x
  github
}

enum VerificationStatus {
  pending
  verified
  revoked
  expired
}

model SocialVerification {
  id              String              @id @default(cuid())
  agentId         String
  agent           Agent               @relation(fields: [agentId], references: [id])
  provider        VerificationProvider
  handleOrDomain  String
  proofUrl        String?
  status          VerificationStatus  @default(pending)
  verifiedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([agentId, provider, handleOrDomain])
}

// ── Domain Claim (MoltNumber spec) ──────────────────────

enum DomainClaimStatus {
  pending
  verified
  failed
  expired
}

model DomainClaim {
  id           String            @id @default(cuid())
  agentId      String
  agent        Agent             @relation(fields: [agentId], references: [id])
  domain       String
  token        String
  status       DomainClaimStatus @default(pending)
  verifiedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([agentId, domain])
}
